# Example environment variables for Diamond Runner
# Copy to .env and fill in your real values as needed.
#
# This file is safe to commit and share. Do NOT put real secrets here.

# OpenRouter API key (used for LLM execution)
# The app prefers OS keychain, but will fall back to this if set.
OPENROUTER_API_KEY=your-openrouter-api-key-here

# (Optional) Tauri signing password for local builds (leave blank unless building signed releases)
# TAURI_SIGNING_PRIVATE_KEY_PASSWORD=your-signing-password-here

# Add any other environment variables required by your local setup below.
# For example:
# ANOTHER_SECRET=your-value-here
