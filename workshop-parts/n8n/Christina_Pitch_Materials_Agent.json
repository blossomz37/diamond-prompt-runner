      "parameters": {
        "jsCode": "const metadata = $json.output || $json;\n\nconst formatList = (arr) => arr?.map(item => `• ${item}`).join('\\n') || '';\n\nconst formatted = `\n## PITCH MATERIALS\n\n### LOGLINES:\n${formatList(metadata.loglines)}\n\n### ELEVATOR PITCHES:\n${formatList(metadata.elevatorPitches)}\n\n### TAGLINES:\n${formatList(metadata.taglines)}\n\n### HOOK STATEMENTS:\n${formatList(metadata.hookStatements)}\n`;\n\nreturn [{\n  json: {\n    ...metadata,\n    formattedText: formatted.trim()\n  }\n}];\n"
      },
